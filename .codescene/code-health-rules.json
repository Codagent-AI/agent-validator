{
  "usage": "Custom code health rules for agent-validator. See docs/code-health-improvements.md for deferred issues.",
  "rule_sets": [
    {
      "matching_content_path": "test/**",
      "rules": [
        {
          "name": "Code Duplication",
          "weight": 0.5
        },
        {
          "name": "Duplicated Assertion Blocks",
          "weight": 0.5
        },
        {
          "name": "Large Method",
          "weight": 0.5
        },
        {
          "name": "Primitive Obsession",
          "weight": 0.0
        }
      ]
    },
    {
      "matching_content_path": "src/**",
      "rules": [
        {
          "name": "Code Duplication",
          "weight": 1.0
        }
      ]
    },
    {
      "matching_content_path": "src/commands/**",
      "rules": [
        {
          "name": "Primitive Obsession",
          "weight": 0.5
        }
      ],
      "thresholds": [
        {
          "name": "function_cyclomatic_complexity_warning",
          "value": 12
        }
      ]
    },
    {
      "matching_content_path": "src/hooks/**",
      "rules": [
        {
          "name": "Primitive Obsession",
          "weight": 0.5
        }
      ]
    }
  ]
}