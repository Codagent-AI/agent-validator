{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/index.ts stop-hook",
            "timeout": 300
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun src/index.ts start-hook",
            "async": false
          }
        ],
        "matcher": "startup|resume|clear|compact"
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(bun src/index.ts:*)"
    ]
  }
}
