{
  "name": "agent-validator",
  "version": "1.3.0",
  "description": "A CLI tool for validating AI coding agents",
  "license": "MIT",
  "author": "Paul Caplan",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Codagent-AI/agent-validator.git"
  },
  "homepage": "https://github.com/Codagent-AI/agent-validator",
  "bugs": {
    "url": "https://github.com/Codagent-AI/agent-validator/issues"
  },
  "keywords": [
    "cli",
    "ai",
    "agent",
    "testing",
    "node"
  ],
  "files": [
    "dist",
    "skills",
    ".claude-plugin",
    ".cursor-plugin",
    "hooks",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "agent-validate": "dist/index.js",
    "agent-gauntlet": "dist/index.js"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build:bin": "bun build --compile --minify --sourcemap ./src/index.ts --outfile bin/agent-validate",
    "build:npm": "bun build.ts",
    "prepublishOnly": "bun run build:npm",
    "test": "bun test",
    "test:e2e": "bun run build:npm && bun test test/integration/",
    "lint": "biome check src",
    "typecheck": "tsc --noEmit && tsc --noEmit -p test/tsconfig.json",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "run": "bun src/index.ts run",
    "check": "bun src/index.ts check",
    "clean": "bun src/index.ts clean",
    "review": "bun src/index.ts review",
    "detect": "bun src/index.ts detect",
    "list": "bun src/index.ts list",
    "health": "bun src/index.ts health",
    "validate": "bun src/index.ts validate",
    "demo": "bun src/index.ts demo"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.3",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@types/bun": "latest",
    "@types/picomatch": "^4.0.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.1",
    "@logtape/logtape": "^2.0.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.2",
    "gray-matter": "^4.0.3",
    "picomatch": "^4.0.3",
    "yaml": "^2.8.2",
    "zod": "^4.3.5"
  }
}
