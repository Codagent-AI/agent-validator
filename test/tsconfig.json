{
    "extends": "../tsconfig.json",
    "compilerOptions": {
        // Relax strictness for test files - mocks and assertions often
        // require more lenient typing than production code
        "noUncheckedIndexedAccess": false,
        "strict": true,
        // Skip deep checks on library types - helps with mock typing
        "skipLibCheck": true
    },
    "include": [
        "./**/*.ts"
    ],
    "exclude": [
        // This file has complex child_process.spawn mock typing issues
        // that are difficult to resolve without significant refactoring
        "./utils/execution-state.test.ts"
    ]
}